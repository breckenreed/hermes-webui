# Copy to .env and fill in your values.
# This is the same key your Hermes container uses to reach its LLM endpoint
# (found in ~/.hermes/.env). The webui passes it through to `hermes`.
LLM_CLIENT_UID=sk-lm-xxxxxxxx:yyyyyyyyyyyyyyyy

# Access token for the webui. REQUIRED on any shared/semi-public network —
# without it anyone who reaches the port gets full agent access. Generate a
# long random value, e.g.:  openssl rand -hex 24
WEBUI_TOKEN=

# 1 = serve HTTPS with a self-signed certificate (protects the token and chat
# content from LAN sniffing). Browsers warn once about the cert — accept it.
WEBUI_TLS=0
